# Shared environment reference for local development and deployment.

# Frontend (Vercel or local Next.js)
NEXT_PUBLIC_API_BASE_URL=http://localhost:5001

# Analyze service (public Render web service)
ANALYZE_PORT=5001
EXTRACT_BACKEND_URL=http://localhost:5000
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://lokbhasha.vercel.app
LINGODOTDEV_API_KEY=your_actual_api_key_here
LINGODOTDEV_ENGINE_ID=
LINGODOTDEV_TARGET_LOCALES=as,bn,brx,doi,gu,hi,kn,ks,kok,mai,ml,mni,ne,or,pa,sa,sat,sd,ta,te,ur
GLOSSARY_DB_PATH=./sqlite/glossary.sqlite3
GLOSSARY_SOURCE_PATH=./dict/19k.json

# Extraction service (private Render service or local FastAPI)
BACKEND_PORT=5000
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5001
TESSERACT_LANG=mar+eng
BACKEND_MAX_UPLOAD_BYTES=10485760

# Glossary build
# python scripts/build_glossary_sqlite.py --source ./dict/19k.json --output ./sqlite/glossary.sqlite3

ENV=development
