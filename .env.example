# Shared environment reference for the Cloudflare migration target.

# Frontend (Cloudflare Pages static export or local Next.js)
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8787

# Cloudflare Worker API
CORS_ALLOWED_ORIGINS=http://localhost:3000
LINGODOTDEV_API_KEY=your_actual_api_key_here
LINGODOTDEV_ENGINE_ID=
LINGODOTDEV_TARGET_LOCALES=as,bn,brx,doi,gu,hi,kn,ks,kok,mai,ml,mni,ne,or,pa,sa,sat,sd,ta,te,ur
GLOSSARY_SOURCE_PATH=./dict/19k.json
GLOSSARY_SOURCE_FORMAT=english_to_marathi_list
GLOSSARY_LAST_SYNC_AT=
GLOSSARY_REMOTE_TERM_COUNT=
GLOSSARY_AUTHORITATIVE_ENGINE_ID=
GLOSSARY_AUTHORITATIVE_ENGINE_NAME=

# Lingo engine layer counts (set to match your Lingo dashboard configuration)
LINGO_BRAND_VOICE_COUNT=0
LINGO_INSTRUCTION_COUNT=0
LINGO_SCORER_COUNT=0

# Cloudflare D1 seed build
# cd cloudflare-api
# npm run build:d1

# TestSprite MCP
TESTSPRITE_API_KEY=

ENV=development
