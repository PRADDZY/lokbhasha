# Shared environment reference.
# Next.js reads frontend/.env.local or host-provided env vars.
# The FastAPI extraction service can read shell exports or backend/.env.

# Backend Configuration
BACKEND_URL=http://localhost:5000
BACKEND_PORT=5000
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# Lingo.dev API Configuration
LINGODOTDEV_API_KEY=your_actual_api_key_here
LINGODOTDEV_TARGET_LOCALES=hi,gu

# OCR Configuration
TESSERACT_LANG=mar+eng

# Frontend / Node Runtime Configuration
NEXT_PUBLIC_BACKEND_URL=http://localhost:5000
# Path to the built glossary SQLite artifact used by the Next.js analyze route.
GLOSSARY_DB_PATH=./dict/glossary.sqlite3

# Glossary build
# python scripts/build_glossary_sqlite.py --source ./dict/lingo_dev_mr_en.json --output ./dict/glossary.sqlite3

# Environment

ENV=development
